# Application
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# API server
API_HOST=127.0.0.1
API_PORT=8000

# Model provider
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
MODEL_TEMPERATURE=0

# Provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# LangSmith / tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=TCMAgent

# UI / frontend integration
DEEP_AGENTS_UI_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Safety / workflow thresholds
TRIAGE_HIGH_RISK_THRESHOLD=0.8
CONVERGENCE_THRESHOLD=0.75
INTAKE_COMPLETENESS_THRESHOLD=0.7

# Runtime behavior
ENABLE_AUDIT_LOG=true
ENABLE_REASONING_TRACE=true
ENABLE_HUMAN_REVIEW=true
